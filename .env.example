APP_NAME="Multimodal Parsing Agent"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
API_PREFIX="/api/v1"
LOG_LEVEL="INFO"

# Local MVP fallback:
DATABASE_URL="sqlite:///./local.db"

# PostgreSQL example:
# DATABASE_URL="postgresql+psycopg://mpa:mpa@localhost:5432/mpa"

STORAGE_DIR="./storage"
MAX_UPLOAD_BYTES=52428800
CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000/api/v1"

# Local OCR / VLM support.
# On macOS, install the system OCR binary with: brew install tesseract
TESSERACT_CMD=""
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LM_STUDIO_VLM_MODEL="google/gemma-4-12b"
LM_STUDIO_TIMEOUT_SECONDS=60
LM_STUDIO_MAX_PDF_PAGES=3

# Optional local embeddings through LM Studio's OpenAI-compatible endpoint.
LM_STUDIO_EMBEDDING_ENABLED=false
LM_STUDIO_EMBEDDING_MODEL="text-embedding-nomic-embed-text-v1.5"

# Agent task worker / queue controls.
# Keep background enabled for local dev so API-created tasks execute immediately.
# Set AGENT_TASK_BACKGROUND_ENABLED=false when running dedicated workers only.
AGENT_TASK_BACKGROUND_ENABLED=true
AGENT_TASK_MAX_ATTEMPTS=3
AGENT_TASK_LOCK_TIMEOUT_SECONDS=300
AGENT_TASK_RETRY_BACKOFF_SECONDS=30
